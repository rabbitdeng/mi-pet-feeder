# === 方式1（推荐）: 使用浏览器提取的 token，无需密码 ===
# 1. 在浏览器中登录 https://account.xiaomi.com
# 2. 完成身份验证
# 3. F12 → Application → Cookies → account.xiaomi.com
# 4. 复制 userId 和 passToken 的值
MI_USER_ID=your_user_id
MI_PASS_TOKEN=your_pass_token

# === 方式2: 使用小米账号密码登录 ===
# 注意：可能需要浏览器身份验证
MI_USER=your_xiaomi_account@example.com
MI_PASS=your_password

# 喂食器 DID
FEEDER_DID=your_device_did

# 温湿度计 DID（可选，不填则不显示环境数据）
SENSOR_DID=your_sensor_did
